SELECT customers.name, products.product_name, orders.quantity, products.price, orders.order_date
FROM orders
JOIN customers ON orders.customer_id = customers.customer_id
JOIN products ON orders.product_id = products.product_id
ORDER BY orders.order_date;

SELECT * FROM orders
WHERE quantity * (SELECT price FROM products WHERE products.product_id = orders.product_id)
=
(SELECT MAX(quantity * price)
 FROM orders
 JOIN products ON orders.product_id = products.product_id);

SELECT name FROM customers
WHERE customer_id =
(
    SELECT customer_id
    FROM orders
    GROUP BY customer_id
    ORDER BY COUNT(order_id) DESC
    LIMIT 1
);
